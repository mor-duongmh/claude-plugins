{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${MORKIT_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/session-start.sh\"",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${MORKIT_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/pre-tool-checklist-gate.sh\"",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${MORKIT_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/userpromptsubmit-route.sh\"",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${MORKIT_REPO_ROOT:-.}/.claude/helpers/hook-handler.cjs\" record-outcome",
            "async": true
          }
        ]
      }
    ]
  }
}
